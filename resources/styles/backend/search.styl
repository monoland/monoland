.v-search
    align-items: center
    background-color: $grey.lighten-4
    display: flex
    height: 72px
    padding: 12px 22px 12px 4px
    top: 0px
    width: 60%
    transition: width 0.2s cubic-bezier(0.25, 0.8, 0.5, 1);
    will-change: width

    &__text
        border-radius: 3px
        height: 48px
        color: $blue-grey.base
        font-size: 24px
        font-weight: 300
        outline: none
        padding: 0 8px
        width: 100%

        &--focus
            background: rgba(255, 255, 255, 0.6)
