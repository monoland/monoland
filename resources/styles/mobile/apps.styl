.message-box
    display: flex
    align-items: center

.message-logo
    border-radius: 5px
    display: flex
    min-height: 120px
    justify-content: center
    min-width: 120px
    overflow: hidden

    &__wrap
        height: 100%

        img 
            height: 100%
            width: auto

.message-text
    padding-left: 16px

.brand-name
    margin-left: -4px

.brand-copy
    font-weight: 500
    font-size: 15px

.v-mobile
    position: relative
    height: 100vh
    width: 100vw
    padding-bottom: 56px
    z-index: 0
    overflow: hidden

    &__wrap
        width: 100%
        height: 100%
        overflow-y: auto